import { Router } from 'express'
import * as controller from '../controllers/{{lowerModel}}.controller'

const router = Router()

{{#if hasCreate}}
router.post('/',      controller.create{{model}})
{{/if}}
{{#if hasList}}
router.get('/',       controller.get{{model}}s)
{{/if}}
{{#if hasGet}}
router.get('/:id',    controller.get{{model}}ById)
{{/if}}
{{#if hasUpdate}}
router.put('/:id',    controller.update{{model}})
{{/if}}
{{#if hasDelete}}
router.delete('/:id', controller.delete{{model}})
{{/if}}

export default router
