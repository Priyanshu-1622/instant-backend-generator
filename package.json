{
  "name": "instant-backend-generator",
  "version": "1.1.0",
  "description": "Generate a production-ready Node.js REST backend from a schema — in seconds.",
  "main": "dist/index.js",
  "bin": {
    "instant-backend": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build":            "tsc && cp -r src/templates dist/templates",
    "start":            "node dist/index.js",
    "dev":              "ts-node src/index.ts",
    "prepare":          "npm run build",
    "test:integration": "playwright test",
    "test:install":     "playwright install chromium"
  },
  "keywords": [
    "cli", "node", "express", "prisma", "zod",
    "backend-generator", "typescript", "clean-architecture",
    "code-generation", "scaffolding", "rest-api"
  ],
  "author": "Priyanshu",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "commander":      "^12.0.0",
    "dotenv":         "^16.0.0",
    "express":        "^4.18.0",
    "fs-extra":       "^11.0.0",
    "handlebars":     "^4.7.9",
    "prompts":        "^2.4.2",
    "zod":            "^3.22.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/express":   "^4.17.0",
    "@types/fs-extra":  "^11.0.0",
    "@types/node":      "^20.0.0",
    "@types/prompts":   "^2.4.9",
    "prisma":           "^6.0.0",
    "ts-node":          "^10.9.2",
    "typescript":       "^5.0.0"
  }
}
