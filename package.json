    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "fs-extra": "^11.3.4",
    "handlebars": "^4.7.9",
    "prompts": "^2.4.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^20.19.39",
    "@types/prompts": "^2.4.9",
